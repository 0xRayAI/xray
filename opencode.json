{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "mcp": {
    "context7": { "enabled": false },
    "global-everything": { "enabled": false },
    "global-filesystem": { "enabled": false },
    "global-git": { "enabled": false },
    "global-sqlite": { "enabled": false },
    "grep_app": { "enabled": false },
    "orchestrator": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/orchestrator.server.js"],
      "enabled": true
    },
    "enhanced-orchestrator": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/enhanced-orchestrator.server.js"],
      "enabled": true
    },
    "enforcer": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/enforcer-tools.server.js"],
      "enabled": true
    },
    "api-design": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/api-design.server.js"],
      "enabled": true
    },
    "architecture-patterns": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/architecture-patterns.server.js"],
      "enabled": true
    },
    "git-workflow": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/git-workflow.server.js"],
      "enabled": true
    },
    "performance-optimization": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/performance-optimization.server.js"],
      "enabled": true
    },
    "project-analysis": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/project-analysis.server.js"],
      "enabled": true
    },
    "testing-strategy": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/testing-strategy.server.js"],
      "enabled": true
    },
    "code-review": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/code-review.server.js"],
      "enabled": true
    },
    "security-audit": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/security-audit.server.js"],
      "enabled": true
    },
    "ui-ux-design": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/ui-ux-design.server.js"],
      "enabled": true
    },
    "refactoring-strategies": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/refactoring-strategies.server.js"],
      "enabled": true
    },
    "testing-best-practices": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/testing-best-practices.server.js"],
      "enabled": true
    },
    "librarian": {
      "type": "local",
      "command": ["node", "./node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/project-analysis.server.js"],
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "mode": "subagent",
      "temperature": 0.15,
      "maxTokens": 4096
    },
    "enhanced-orchestrator": {
      "mode": "subagent",
      "temperature": 0.15,
      "maxTokens": 4096
    },
    "enforcer": {
      "mode": "primary",
      "temperature": 0.05,
      "maxTokens": 600
    },
    "architect": {
      "mode": "subagent",
      "temperature": 0.1,
      "maxTokens": 800
    },
    "test-architect": {
      "mode": "subagent",
      "temperature": 0.15,
      "maxTokens": 4096
    },
    "bug-triage-specialist": {
      "mode": "subagent",
      "temperature": 0.1,
      "maxTokens": 3072
    },
    "code-reviewer": {
      "mode": "subagent",
      "temperature": 0.1,
      "maxTokens": 800
    },
    "security-auditor": {
      "mode": "subagent",
      "temperature": 0.1,
      "maxTokens": 3072
    },
    "refactorer": {
      "mode": "subagent",
      "temperature": 0.1,
      "maxTokens": 800
    },
    "Sisyphus": { "disable": true },
    "Planner-Sisyphus": { "disable": true },
    "Build": { "disable": true },
    "Plan": { "disable": true }
  }
}