{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "plugin": [
    "strray-codex-injection"
  ],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "mcp": {
    "context7": { "enabled": false },
    "global-everything": { "enabled": false },
    "global-filesystem": { "enabled": false },
    "global-git": { "enabled": false },
    "orchestrator": {
      "type": "local",
      "command": ["node", "./dist/mcps/orchestrator.server.js"],
      "enabled": true
    },
    "enhanced-orchestrator": {
      "type": "local",
      "command": ["node", "./dist/mcps/enhanced-orchestrator.server.js"],
      "enabled": true
    },
    "enforcer": {
      "type": "local",
      "command": ["node", "./dist/mcps/enforcer-tools.server.js"],
      "enabled": true
    },
    "api-design": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/api-design.server.js"],
      "enabled": true
    },
    "architecture-patterns": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/architecture-patterns.server.js"],
      "enabled": true
    },
    "git-workflow": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/git-workflow.server.js"],
      "enabled": true
    },
    "performance-optimization": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/performance-optimization.server.js"],
      "enabled": true
    },
    "project-analysis": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/project-analysis.server.js"],
      "enabled": true
    },
    "testing-strategy": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/testing-strategy.server.js"],
      "enabled": true
    },
    "code-review": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/code-review.server.js"],
      "enabled": true
    },
    "security-audit": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/security-audit.server.js"],
      "enabled": true
    },
    "ui-ux-design": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/ui-ux-design.server.js"],
      "enabled": true
    },
    "refactoring-strategies": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/refactoring-strategies.server.js"],
      "enabled": true
    },
    "testing-best-practices": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/testing-best-practices.server.js"],
      "enabled": true
    },
    "librarian": {
      "type": "local",
      "command": ["node", "./dist/mcps/knowledge-skills/project-analysis.server.js"],
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "enhanced-orchestrator": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "enforcer": {
      "temperature": 1.0,
      "mode": "primary"
    },
    "architect": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "test-architect": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "bug-triage-specialist": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "code-reviewer": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "security-auditor": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "refactorer": {
      "temperature": 1.0,
      "mode": "subagent"
    },
    "sisyphus": {
      "disable": true
    },
    "Planner-Sisyphus": {
      "disable": true
    },
    "OpenCode-Builder": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "strray-architect": {
      "disable": true
    },
    "strray-orchestrator": {
      "disable": true
    },
    "strray-librarian": {
      "disable": true
    },
    "strray-refactorer": {
      "disable": true
    },
    "strray-security-auditor": {
      "disable": true
