    "strray-boot-orchestrator": {
      "disable": true
    },
    "strray-auto-format": {
      "disable": true
    },
    "strray-architect-tools": {
      "disable": true
    },
    "strray-ui-ux-design": {
      "disable": true
    },
    "strray-testing-strategy": {
      "disable": true
    },
    "strray-testing-best-practices": {
      "disable": true
    },
    "strray-project-analysis": {
      "disable": true
    },
    "strray-performance-optimization": {
      "disable": true
