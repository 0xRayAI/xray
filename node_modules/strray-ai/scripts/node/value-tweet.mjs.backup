#!/usr/bin/env node

/**
 * Value-Focused Tweet Generator for StringRay
 *
 * Analyzes the actual changes in a release to extract REAL user value.
 * NOT just filtering by commit type - looks at WHAT was changed and WHY.
 *
 * Examples of user value to extract:
 * - New documentation (AGENTS.md - 584 lines)
 * - Configuration improvements (features.json updates)
 * - Simplified workflows (lower orchestration complexity)
 * - Better UX ( clearer instructions, easier usage)
 *
 * Usage:
 *   node scripts/node/value-tweet.mjs
 *   node scripts/node/value-tweet.mjs --preview
 */

import { execSync } from 'child_process';
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const rootDir = path.resolve(__dirname, '../..');

/**
 * Get current version from package.json
 */
function getCurrentVersion() {
  const pkg = JSON.parse(fs.readFileSync(path.join(rootDir, 'package.json'), 'utf-8'));
  return pkg.version;
}

/**
 * Get the latest git tag
 */
function getLatestTag() {
  try {
    const tag = execSync('git describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0"', {
      cwd: rootDir,
      encoding: 'utf-8'
    }).trim();
    return tag || 'v0.0.0';
  } catch {
    return 'v0.0.0';
  }
}

/**
 * Get the previous tag
 */
function getPreviousTag(latestTag) {
  try {
    const allTags = execSync('git tag -l', {
      cwd: rootDir,
      encoding: 'utf-8'
    }).trim().split('\n').map(t => t.trim()).filter(Boolean);

    const versionTags = allTags
      .filter(tag => tag.startsWith('v1.7.'))
      .sort((a, b) => {
        const [_, minorA, patchA] = a.split('.').map(Number);
        const [__, minorB, patchB] = b.split('.').map(Number);
        return patchB - patchA;
      });

    const latestIndex = versionTags.indexOf(latestTag);
    if (latestIndex >= 0 && latestIndex + 1 < versionTags.length) {
      return versionTags[latestIndex + 1];
    }
    return null;
  } catch {
    return null;
  }
}

/**
 * Get commits between two tags
 */
function getCommitsBetweenTags(fromTag, toTag) {
  try {
    const commits = execSync(
      `git log ${fromTag}..${toTag} --oneline --format="%s||%h"`,
      { cwd: rootDir, encoding: 'utf-8' }
    ).trim().split('\n').filter(Boolean);

    return commits.map(commit => {
      const [message, hash] = commit.split('||');
      return { message: message.trim(), hash: hash.trim() };
    });
  } catch {
    return [];
  }
}

/**
 * Get files changed in commits
 */
function getChangedFiles(commits) {
  const allFiles = new Set();

  for (const commit of commits) {
    try {
      const changedFiles = execSync(
        `git show ${commit.hash} --name-only --format=""`,
        { cwd: rootDir, encoding: 'utf-8' }
      ).trim().split('\n').filter(Boolean);

      for (const file of changedFiles) {
        allFiles.add(file);
      }
    } catch {
      // Skip commits that can't be analyzed
    }
  }

  return Array.from(allFiles);
}

/**
 * Analyze a file to extract user value
 */
function analyzeFileValue(filePath) {
  const fullPath = path.join(rootDir, filePath);

  if (!fs.existsSync(fullPath)) {
    return null;
  }

  try {
    const content = fs.readFileSync(fullPath, 'utf-8');
    const stats = fs.statSync(fullPath);

    // Skip binaries or too large files
    if (stats.size > 100000) {
      return null;
    }

    const lines = content.split('\n').length;
    const valuePoints = [];

    // Documentation files
    if (filePath.endsWith('.md')) {
      valuePoints.push('documentation');

      if (filePath.toLowerCase().includes('agent')) {
        valuePoints.push('agent guide');

        // Count how many agents documented
        const agentCount = (content.match(/@\w+/g) || []).length;
        if (agentCount > 5) {
          valuePoints.push(`${agentCount}+ agents documented`);
        }
      }

      if (filePath.toLowerCase().includes('readme')) {
        valuePoints.push('getting started guide');
      }

      if (filePath.toLowerCase().includes('changelog')) {
        valuePoints.push('release notes');
      }
    }

    // Configuration files
    if (filePath.endsWith('.json')) {
      valuePoints.push('configuration');

      if (filePath.toLowerCase().includes('feature')) {
        valuePoints.push('feature flags');
      }

      if (filePath.toLowerCase().includes('package')) {
        valuePoints.push('package updates');
      }
    }

    // Script files
    if (filePath.endsWith('.js') || filePath.endsWith('.mjs') || filePath.endsWith('.ts')) {
      valuePoints.push('automation');

      if (filePath.toLowerCase().includes('release') || filePath.toLowerCase().includes('version')) {
        valuePoints.push('release automation');
      }

      if (filePath.toLowerCase().includes('tweet')) {
        valuePoints.push('tweet generation');
      }
    }

    return {
      file: filePath,
      lines,
      size: stats.size,
      value: valuePoints.length > 0 ? valuePoints.join(', ') : null,
      category: getCategory(filePath)
    };
  } catch {
    return null;
  }
}

/**
 * Get category of a file
 */
function getCategory(filePath) {
  const lowerPath = filePath.toLowerCase();

  if (lowerPath.includes('docs/') || lowerPath.endsWith('.md')) {
    return 'documentation';
  }

  if (lowerPath.includes('.json') || lowerPath.includes('config')) {
    return 'configuration';
  }

  if (lowerPath.includes('scripts/') || lowerPath.endsWith('.js') || lowerPath.endsWith('.mjs')) {
    return 'automation';
  }

  if (lowerPath.includes('test') || lowerPath.includes('__tests__')) {
    return 'testing';
  }

  if (lowerPath.includes('src/')) {
    return 'source-code';
  }

  return 'other';
}

/**
 * Extract user value from release changes
 */
function extractUserValue(commits, changedFiles) {
  const analyzedFiles = [];
  const valueSummary = {
    documentation: [],
    configuration: [],
    automation: [],
    features: [],
    improvements: []
  };

  for (const file of changedFiles) {
    const analysis = analyzeFileValue(file);
    if (analysis && analysis.value) {
      analyzedFiles.push(analysis);

      // Categorize by value
      if (analysis.category === 'documentation') {
        valueSummary.documentation.push(analysis);
      }

      if (analysis.category === 'configuration') {
        valueSummary.configuration.push(analysis);
      }

      if (analysis.category === 'automation') {
        valueSummary.automation.push(analysis);
      }
    }
  }

  // Also analyze commit messages for explicit user value
  for (const commit of commits) {
    const msg = commit.message.toLowerCase();

    if (msg.includes('complexity') || msg.includes('simplify')) {
      valueSummary.improvements.push({
        source: 'commit',
        value: 'simplified workflow',
        description: commit.message
      });
    }

    if (msg.includes('better') || msg.includes('improve') || msg.includes('enhance')) {
      valueSummary.improvements.push({
        source: 'commit',
        value: 'improved user experience',
        description: commit.message
      });
    }

    if (msg.includes('add') && (msg.includes('agent') || msg.includes('feature'))) {
      valueSummary.features.push({
        source: 'commit',
        value: 'new features',
        description: commit.message
      });
    }
  }

  return {
    analyzedFiles,
    valueSummary
  };
}

/**
 * Generate value-focused tweet
 */
function generateValueTweet(version, valueData) {
  const { analyzedFiles, valueSummary } = valueData;

  const parts = [`🚀 StringRay v${version} released!`];

  // Build value highlights from actual changes
  const highlights = [];

  // Documentation highlights
  if (valueSummary.documentation.length > 0) {
    const docs = valueSummary.documentation;
    const totalLines = docs.reduce((sum, d) => sum + d.lines, 0);

    if (docs.some(d => d.file.toLowerCase().includes('agents.md'))) {
      highlights.push(`📚 Complete agent documentation (${totalLines}+ lines)`);
    } else if (totalLines > 200) {
      highlights.push(`📚 Comprehensive documentation (${totalLines}+ lines)`);
    } else {
      highlights.push(`📚 Better documentation`);
    }
  }

  // Configuration highlights
  if (valueSummary.configuration.length > 0) {
    const configFiles = valueSummary.configuration;
    if (configFiles.some(c => c.file.toLowerCase().includes('feature'))) {
      highlights.push(`⚙️ Updated feature flags`);
    } else if (configFiles.some(c => c.file.toLowerCase().includes('package'))) {
      highlights.push(`📦 Package improvements`);
    } else {
      highlights.push(`⚙️ Better configuration`);
    }
  }

  // Automation highlights
  if (valueSummary.automation.length > 0) {
    const automation = valueSummary.automation;
    if (automation.some(a => a.file.toLowerCase().includes('release'))) {
      highlights.push(`🔄 Automated releases`);
    } else if (automation.some(a => a.file.toLowerCase().includes('version'))) {
      highlights.push(`📦 Version automation`);
    } else {
      highlights.push(`⚡ Better automation`);
    }
  }

  // Improvements from commits
  if (valueSummary.improvements.length > 0) {
    const improvements = valueSummary.improvements;

    if (improvements.some(i => i.value.includes('simplified') || i.value.includes('complexity'))) {
      highlights.push(`📉 Lowered complexity`);
    }

    if (improvements.some(i => i.value.includes('improved') || i.value.includes('better'))) {
      highlights.push(`✨ Better user experience`);
    }
  }

  // Features from commits
  if (valueSummary.features.length > 0) {
    highlights.push(`🆕 New features`);
  }

  // If no highlights found, use generic
  if (highlights.length === 0) {
    if (analyzedFiles.length > 0) {
      highlights.push(`✅ Production-ready improvements`);
    } else {
      highlights.push(`✅ Ready for production`);
    }
  }

  // Add highlights to tweet
  if (highlights.length > 0) {
    parts.push(highlights.slice(0, 3).join(' • '));
  }

  // Stats
  const stats = [];
  const docCount = valueSummary.documentation.length;
  const configCount = valueSummary.configuration.length;
  const autoCount = valueSummary.automation.length;

  if (docCount > 0) stats.push(`${docCount} docs`);
  if (configCount > 0) stats.push(`${configCount} configs`);
  if (autoCount > 0) stats.push(`${autoCount} automation`);

  if (stats.length > 0) {
    parts.push(`\n📊 ${stats.join(' • ')}`);
  }

  // Hashtags and link
  parts.push('\n#StringRay #AI #DevTools');
  parts.push('🔗 https://github.com/htafolla/stringray');

  return parts.join('\n');
}

function main() {
  const args = process.argv.slice(2);
  const previewOnly = args.includes('--preview') || args.includes('-p');

  console.log('\n' + '='.repeat(50));
  console.log('🐦 Value-Focused Tweet Generator for StringRay');
  console.log('='.repeat(50));

  const latestTag = getLatestTag();
  const previousTag = getPreviousTag(latestTag);
  const commits = previousTag ? getCommitsBetweenTags(previousTag, latestTag) : [];
  const currentVersion = getCurrentVersion();

  console.log(`\n📦 Latest tag: ${lastTag}`);
  console.log(`📦 Current version: ${currentVersion}`);
  console.log(`📝 Commits in release: ${commits.length}`);

  if (commits.length === 0) {
    console.log('\n⚠️  No commits found in this release.');
    console.log('   This might be the first release or no changes.');
    process.exit(1);
  }

  const changedFiles = getChangedFiles(commits);
  console.log(`📁 Files changed: ${changedFiles.length}`);

  if (changedFiles.length > 0) {
    console.log('\n📋 Changed files:');
    changedFiles.slice(0, 10).forEach(file => console.log(`  - ${file}`));
    if (changedFiles.length > 10) {
      console.log(`  ... and ${changedFiles.length - 10} more`);
    }
  }

  const valueData = extractUserValue(commits, changedFiles);

  console.log('\n🔍 User Value Analysis:');
  console.log(`  Documentation: ${valueData.valueSummary.documentation.length} files`);
  console.log(`  Configuration: ${valueData.valueSummary.configuration.length} files`);
  console.log(`  Automation: ${valueData.valueSummary.automation.length} files`);
  console.log(`  Improvements: ${valueData.valueSummary.improvements.length} items`);

  if (valueData.valueSummary.documentation.length > 0) {
    console.log('\n📚 Documentation highlights:');
    valueData.valueSummary.documentation.slice(0, 3).forEach(doc => {
      console.log(`  - ${doc.file}: ${doc.lines} lines, ${doc.value}`);
    });
  }

  const tweet = generateValueTweet(currentVersion, valueData);

  console.log('\n' + '─'.repeat(45));
  console.log('--- Generated Tweet ---');
  console.log('─'.repeat(45));
  console.log(tweet);
  console.log('─'.repeat(45));

  const charCount = tweet.length;
  console.log(`\n📊 Tweet length: ${charCount} characters (max 280)`);

  if (charCount > 280) {
    console.log('⚠️  Warning: Tweet exceeds 280 characters!');
  }

  if (previewOnly) {
    console.log('\n✅ Preview mode - not saving to file.');
    console.log('   Remove --preview to save.\n');
    process.exit(0);
  }

  // Save to file
  const tweetsDir = path.join(rootDir, 'tweets');
  if (!fs.existsSync(tweetsDir)) {
    fs.mkdirSync(tweetsDir, { recursive: true });
  }

  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
  const filename = path.join(tweetsDir, `tweet-v${currentVersion}-${timestamp}.txt`);

  fs.writeFileSync(filename, tweet + '\n', 'utf-8');
  console.log(`\n✅ Saved tweet to: ${filename}`);
}

main();
