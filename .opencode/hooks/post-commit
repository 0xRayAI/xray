#!/bin/bash
# StringRay Post-Commit Hook
# Runs activity logging, analytics, log cleanup, and auto-reflection after commit
# Does NOT block — runs in background

# Get absolute path to project root - handle .opencode/hooks structure
HOOK_PATH="$(cd "$(dirname "$0")" && pwd)"
if [[ "$HOOK_PATH" == *".opencode/hooks" ]]; then
  # Running from .opencode/hooks
  PROJECT_ROOT="$(cd "$HOOK_PATH/../.." && pwd)"
else
  # Running from hooks/ at project root
  PROJECT_ROOT="$(cd "$HOOK_PATH/.." && pwd)"
fi

# Fallback: if we can't determine, use current directory
if [ -z "$PROJECT_ROOT" ] || [ ! -d "$PROJECT_ROOT" ]; then
  PROJECT_ROOT="$(pwd)"
fi

COMMIT_SHA=$(git -C "$PROJECT_ROOT" rev-parse HEAD 2>/dev/null || echo "unknown")
BRANCH=$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

# Run in background — never block git operations
(
  if command -v node >/dev/null 2>&1; then
    export HOOK_TYPE="post-commit"
    export COMMIT_SHA="$COMMIT_SHA"
    export BRANCH="$BRANCH"
    export PROJECT_ROOT="$PROJECT_ROOT"
    node "$PROJECT_ROOT/scripts/hooks/run-hook.js" post-commit 2>/dev/null || true
  fi
) &

# Load auto_reflection config from features.json
CONFIG_FILE="$PROJECT_ROOT/.opencode/strray/features.json"
MODE="minimal"
COMMIT_THRESHOLD=25
DAYS_THRESHOLD=14
AUTO_GENERATE=true
PROMPT_USER=true

if [ -f "$CONFIG_FILE" ]; then
  MODE=$(grep -o '"mode": *"[^"]*"' "$CONFIG_FILE" | cut -d'"' -f4)
  MODE=${MODE:-minimal}
  
  # Get thresholds based on mode
  case "$MODE" in
    full)
      COMMIT_THRESHOLD=10
      DAYS_THRESHOLD=5
      AUTO_GENERATE=true
      PROMPT_USER=true
      ;;
    minimal)
      COMMIT_THRESHOLD=25
      DAYS_THRESHOLD=14
      AUTO_GENERATE=true
      PROMPT_USER=true
      ;;
    off)
      COMMIT_THRESHOLD=999
      DAYS_THRESHOLD=365
      AUTO_GENERATE=false
      PROMPT_USER=false
      ;;
  esac
fi

# Check if this was a significant commit - prompt for reflection
COMMIT_MSG=$(git -C "$PROJECT_ROOT" log -1 --pretty=%B)
SIGNIFICANT_KEYWORDS="fix|bug|debug|deploy|release|feature|refactor|kernel|learning|pattern|wire|connect|integrate"

if echo "$COMMIT_MSG" | grep -qiE "$SIGNIFICANT_KEYWORDS" && [ "$PROMPT_USER" = true ]; then
  echo ""
  echo "📝 REFLECTION SUGGESTION: This commit appears to involve significant changes."
  echo "   Consider writing a reflection using the v3.0 template:"
  echo "   → cat docs/reflections/TEMPLATE_v3.md"
  echo ""
  echo "   To validate a reflection before committing:"
  echo "   → ./scripts/node/reflection-validate.sh <path-to-reflection>"
  echo ""
fi

# Auto-reflection check - count commits since last reflection
if [ "$AUTO_GENERATE" = true ] && [ -d "$PROJECT_ROOT/docs/reflections" ]; then
  LAST_REFLECTION=$(find "$PROJECT_ROOT/docs/reflections" -name "*.md" -type f -exec stat --format="%Y" {} \; 2>/dev/null | sort -rn | head -1)
  
  if [ -n "$LAST_REFLECTION" ]; then
    REFLECTION_EPOCH=$(date -r "$LAST_REFLECTION" +%s 2>/dev/null || echo "0")
    NOW_EPOCH=$(date +%s)
    DAYS_SINCE=$(( (NOW_EPOCH - REFLECTION_EPOCH) / 86400 ))
    
    # Also count commits since then
    COMMITS_SINCE=$(git -C "$PROJECT_ROOT" log --since="$LAST_REFLECTION" --oneline 2>/dev/null | wc -l | tr -d ' ')
  else
    DAYS_SINCE=999
    COMMITS_SINCE=$(git -C "$PROJECT_ROOT" rev-list --count HEAD 2>/dev/null || echo "0")
  fi
  
  # Threshold check
  if [ "$COMMITS_SINCE" -gt "$COMMIT_THRESHOLD" ] || [ "$DAYS_SINCE" -gt "$DAYS_THRESHOLD" ]; then
    echo ""
    echo "⚠️  AUTO-REFLECTION TRIGGERED (mode: $MODE)"
    echo "   $COMMITS_SINCE commits since last reflection ($DAYS_SINCE days)"
    echo "   Thresholds: $COMMIT_THRESHOLD commits, $DAYS_THRESHOLD days"
    echo ""
    
    if [ "$MODE" != "off" ]; then
      # Generate reflection stub
      cd "$PROJECT_ROOT"
      node scripts/node/auto-reflection-generator.mjs --trigger commit-threshold \
        --title "Multiple commits since last reflection" 2>/dev/null || true
      
      GENERATED_FILE=$(ls -t docs/reflections/auto-commit-*.md 2>/dev/null | head -1)
      if [ -n "$GENERATED_FILE" ]; then
        echo "   ✅ Generated: $GENERATED_FILE"
        echo "   → Fill in the details and commit"
      fi
    else
      echo "   Auto-reflection is OFF. Set mode to 'full' or 'minimal' in features.json to enable."
    fi
  fi
fi

# Auto-reporting: Generate reports after commit
REPORT_ENABLED=true
REPORT_COMMIT_TRIGGER=1
REPORT_OUTPUT_DIR=".ci-reports"

if [ -f "$CONFIG_FILE" ]; then
  REPORT_ENABLED=$(grep -o '"auto_reporting": *{[^}]*enabled": *[^,}]*' "$CONFIG_FILE" | grep -o 'enabled": *[^,}]*' | cut -d'"' -f3 || echo "true")
  REPORT_ENABLED=${REPORT_ENABLED:-true}
  
  REPORT_MODE=$(grep -o '"auto_reporting": *{[^}]*mode": *"[^"]*"' "$CONFIG_FILE" | cut -d'"' -f4)
  REPORT_MODE=${REPORT_MODE:-full}
  
  case "$REPORT_MODE" in
    full)
      REPORT_COMMIT_TRIGGER=1
      ;;
    minimal)
      REPORT_COMMIT_TRIGGER=5
      ;;
    off)
      REPORT_ENABLED=false
      ;;
  esac
fi

if [ "$REPORT_ENABLED" = true ]; then
  # Check time since last report - get actual latest file
  REPORT_AGE_MINUTES=999
  if [ -d "$PROJECT_ROOT/$REPORT_OUTPUT_DIR" ]; then
    # Get most recently modified JSON file
    LATEST_FILE=$(ls -t "$PROJECT_ROOT/$REPORT_OUTPUT_DIR"/*.json 2>/dev/null | head -1)
    if [ -n "$LATEST_FILE" ] && [ -f "$LATEST_FILE" ]; then
      LAST_MOD=$(stat -f %m "$LATEST_FILE" 2>/dev/null)
      NOW_EPOCH=$(date +%s)
      REPORT_AGE_MINUTES=$(( (NOW_EPOCH - LAST_MOD) / 60 ))
    fi
  fi
  
  # Generate reports on commit (always in full mode, time-based in minimal)
  if [ "$REPORT_MODE" = "full" ] || [ "$REPORT_AGE_MINUTES" -gt 60 ] || [ ! -d "$PROJECT_ROOT/$REPORT_OUTPUT_DIR" ]; then
    echo ""
    echo "📊 AUTO-REPORTING: Generating reports..."
    
    # Generate CI reports (use correct arg format)
    cd "$PROJECT_ROOT"
    node scripts/node/ci-report-generator.mjs all 2>/dev/null || true
    
    # Generate session summary
    if [ -f "dist/reporting/autonomous-report-generator.js" ]; then
      node --input-type=module -e "
import { AutonomousReportGenerator } from './dist/reporting/autonomous-report-generator.js';
const gen = new AutonomousReportGenerator();
const report = await gen.generateDiagnosticReport('post-commit');
console.log('📊 Session Report:', report.summary?.recommendation || 'Generated');
" 2>/dev/null || true
    fi
    
    # Update index for AI discovery
    if [ -d "$PROJECT_ROOT/$REPORT_OUTPUT_DIR" ]; then
      > "$REPORT_OUTPUT_DIR/index.json"
      for f in "$PROJECT_ROOT/$REPORT_OUTPUT_DIR"/*.json; do
        [ -f "$f" ] || continue
        fname=$(basename "$f")
        [ "$fname" = "index.json" ] && continue
        printf '%s\n' "${fname%.json}" >> "$REPORT_OUTPUT_DIR/index.json"
      done
      
      RECENT_COUNT=$(ls -1 "$REPORT_OUTPUT_DIR"/*.json 2>/dev/null | wc -l | tr -d ' ')
      echo "   ✅ Generated $RECENT_COUNT reports in $REPORT_OUTPUT_DIR/"
    fi
  fi
  
  # Display recent report indicators
  if [ -d "$PROJECT_ROOT/$REPORT_OUTPUT_DIR" ] && [ -f "$PROJECT_ROOT/$REPORT_OUTPUT_DIR/index.json" ]; then
    echo ""
    echo "📋 Recent reports: ls $REPORT_OUTPUT_DIR/"
  fi
fi

exit 0
