{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/main/schema.json",
  "plugin": [
    "src/plugin/strray-codex-injection.ts",
    "strray/dist/plugin/strray-codex-injection.js"
  ],
  "settings": {
    "multi_agent_orchestration": {
      "enabled": true,
      "max_concurrent_agents": 3
    }
  },
  "disabled_agents": [
    "Sisyphus",
    "Planner-Sisyphus",
    "Build",
    "Plan"
  ],
  "sisyphus_agent": {
    "disabled": true
  },
  "disabled_mcps": [
    "global-everything",
    "global-git",
    "global-sqlite"
  ],
  "agent": {
    "orchestrator": {
      "mode": "subagent"
    },
    "enhanced-orchestrator": {
      "mode": "subagent"
    },
    "enforcer": {
      "mode": "primary"
    },
    "architect": {
      "mode": "subagent"
    },
    "test-architect": {
      "mode": "subagent"
    },
    "bug-triage-specialist": {
      "mode": "subagent"
    },
    "code-reviewer": {
      "mode": "subagent"
    },
    "security-auditor": {
      "mode": "subagent"
    },
    "refactorer": {
      "mode": "subagent"
    },
    "explore": {
      "mode": "subagent"
    },
    "librarian": {
      "mode": "subagent"
    },
    "multimodal-looker": {
      "mode": "subagent"
    },
    "oracle": {
      "mode": "subagent"
    },
    "analyzer": {
      "mode": "subagent"
    },
    "document-writer": {
      "mode": "subagent"
    },
    "frontend-ui-ux-engineer": {
      "mode": "subagent"
    }
  },
  "mcpServers": {
    "explore": {
      "command": "node",
      "args": [
        "node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/project-analysis.server.js"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "document-writer": {
      "command": "node",
      "args": [
        "node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/documentation-generation.server.js"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "frontend-ui-ux-engineer": {
      "command": "node",
      "args": [
        "node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/ui-ux-design.server.js"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "librarian": {
      "command": "node",
      "args": [
        "node_modules/strray-ai/dist/plugin/mcps/knowledge-skills/project-analysis.server.js"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    }
  }
}