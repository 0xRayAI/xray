#!/usr/bin/env node

/**
 * Single-Release Tweet Generator for StringRay
 * 
 * Generates tweet for CURRENT release only (not historical releases)
 * This is the simpler, more reliable approach.
 */

import { execSync } from 'child_process';
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const rootDir = path.resolve(__dirname, '../..');

/**
 * Get last git tag
 */
function getLastTag() {
  try {
    const lastTag = execSync('git describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0", {
      cwd: rootDir,
      encoding: 'utf-8'
    }).trim();
    
    return lastTag || 'v0.0.0';
  } catch {
    console.error('[ERROR] Failed to get last tag:', e.message);
    return 'v0.0.0';
  }
}

/**
 * Get commits since last tag
 */
function getCommitsSinceLastTag() {
  const lastTag = getLastTag();
  try {
    const commits = execSync(
      `git log ${lastTag}..HEAD --oneline --format="%s||%h"`,
      { cwd: rootDir, encoding: 'utf-8' }
    ).trim().split('\n').filter(Boolean);
    
    return commits.map(commit => {
      const [message, hash] = commit.split('||');
      return { message: message.trim(), hash: hash.trim() };
    });
  } catch {
    console.error('[ERROR] Failed to get commits:', e.message);
    return [];
  }
}

/**
 * Get current version from package.json
 */
function getCurrentVersion() {
  const pkg = JSON.parse(fs.readFileSync(path.join(rootDir, 'package.json'), 'utf-8'));
  return pkg.version;
}

/**
 * Categorize commits by type
 */
function categorizeCommits(commits) {
  const categorized = {
    feat: [],
    fix: [],
    perf: [],
    refactor: [],
    docs: [],
    test: [],
    security: [],
    build: [],
    chore: []
  };
  
  for (const commit of commits) {
    const msg = commit.message.toLowerCase();
    
    if (msg.startsWith('feat:')) {
      categorized.feat.push(commit);
    } else if (msg.startsWith('fix:')) {
      categorized.fix.push(commit);
    } else if (msg.startsWith('perf:') || msg.startsWith('performance:')) {
      categorized.perf.push(commit);
    } else if (msg.startsWith('security:')) {
      categorized.security.push(commit);
    } else if (msg.startsWith('refactor:')) {
      categorized.refactor.push(commit);
    } else if (msg.startsWith('docs:')) {
      categorized.docs.push(commit);
    } else if (msg.startsWith('test:')) {
      categorized.test.push(commit);
    } else if (msg.startsWith('chore:') || msg.startsWith('release:') || msg.startsWith('bump')) {
      categorized.chore.push(commit);
    } else if (msg.startsWith('security:')) {
      categorized.security.push(commit);
    } else if (msg.startsWith('build:')) {
      categorized.build.push(commit);
    }
  }
  
  return categorized;
}

/**
 * Generate tweet text
 */
function generateTweet() {
  const lastTag = getLastTag();
  const commits = getCommitsSinceLastTag();
  const version = getCurrentVersion();
  
  const categorized = categorizeCommits(commits);
  
  const parts = [`🚀 StringRay v${version} released!`];
  
  // Count consumer-facing changes
  const hasConsumerChanges = 
    categorized.feat.length > 0 || 
    categorized.fix.length > 0 || 
    categorized.perf.length > 0 || 
    categorized.security.length > 0;
  
  if (!hasConsumerChanges) {
    parts.push(`✅ Ready for production!`);
  } else {
    // Highlight consumer-facing changes (max 3)
    const highlights = [];
    
    if (categorized.feat.length > 0) {
      const feat = categorized.feat[0].message
        .replace(/^feat:\s*/i, '')
        .replace(/\(.*\)/, '')
        .trim()
        .slice(0, 50);
      highlights.push(`✨ ${feat}`);
    }
    
    if (categorized.fix.length > 0) {
      const fix = categorized.fix[0].message
        .replace(/^fix:\s*/i, '')
        .replace(/\(.*\)/, '')
        .trim()
        .slice(0, 50);
      highlights.push(`🐛 ${fix}`);
    }
    
    if (categorized.perf.length > 0) {
      highlights.push(`⚡ Performance boost`);
    }
    
    if (categorized.security.length > 0) {
      highlights.push(`🔒 Security improvement`);
    }
    
    if (highlights.length > 0) {
      parts.push(highlights.join(' | '));
    }
  }
  
  // Stats (consumer-facing only)
  const stats = [];
  if (categorized.feat.length) {
    stats.push(`${categorized.feat.length} new feature${categorized.feat.length === 1 ? '' : 's'}`);
  }
  if (categorized.fix.length) {
    stats.push(`${categorized.fix.length} fix${categorized.fix.length === 1 ? '' : 'es'}`);
  }
  if (categorized.perf.length) {
    stats.push(`performance`);
  }
  if (categorized.security.length) {
    stats.push(`security`);
  }
  
  if (stats.length > 0) {
    parts.push(`\n📊 ${stats.join(' | ')}`);
  }
  
  // Hashtags and link
  parts.push('\n#StringRay #AI #DevTools');
  parts.push('🔗 https://github.com/htafolla/stringray');
  
  return parts.join('\n\n');
}

function main() {
  const args = process.argv.slice(2);
  const previewOnly = args.includes('--preview') || args.includes('-p');
  
  console.log('\n' + '='.repeat(50));
  console.log('🐦 Single-Release Tweet Generator for StringRay');
  console.log('='.repeat(50));
  
  const lastTag = getLastTag();
  const currentVersion = getCurrentVersion();
  
  console.log(\`\n📌 Last release: ${lastTag}`);
  console.log(`\n📦 Current version: ${currentVersion}`);
  console.log('');
  
  const commits = getCommitsSinceLastTag();
  
  if (commits.length === 0) {
    console.log('\nNo commits found since last release.');
    console.log('Need at least one tagged release.');
    console.log('Run: npm run release:patch --tag first.');
    process.exit(1);
  }
  
  // Generate tweet
  const tweet = generateTweet();
  
  console.log('');
  console.log('--- Commit Summary ---');
  
  commits.forEach(commit => {
    const message = commit.message;
    const hash = commit.hash;
    console.log(\`- ${message} (${hash.substring(0, 7)})`);
  });
  
  console.log('');
  console.log('--- Tweet Preview ---');
  console.log(tweet);
  console.log('--- Tweet Preview ---');
  
  if (previewOnly) {
    console.log('\n✅ Preview mode - not saving to file.');
    console.log('   Remove --preview to save.');
    console.log('');
    process.exit(0);
  }
  
  // Save tweet to file
  const tweetsDir = path.join(rootDir, 'tweets');
  if (!fs.existsSync(tweetsDir)) {
    fs.mkdirSync(tweetsDir, { recursive: true });
  }
  
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
  const filename = path.join(tweetsDir, \`tweet-\${timestamp}.json\`);
  
  const tweetData = {
    generated: timestamp,
    version: currentVersion,
    lastTag: lastTag,
    commitCount: commits.length,
    tweet: tweet,
    commits: commits.map(c => ({
      message: c.message,
      hash: c.hash
    }))
  };
  
  fs.writeFileSync(filename, JSON.stringify(tweetData, null, 2) + '\n');
  
  console.log(`\n✅ Saved tweet to: \${filename}`);
  console.log(`\n📋 Total commits: ${commits.length}`);
  console.log('\n🎯 Ready for tweet!');  // Add line to file
  
  process.exit(0);
}

main();
