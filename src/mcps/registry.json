{
  "version": "3.0.9",
  "description": "0xRay Community MCPs Registry - curated API-focused MCP servers",
  "sources": [
    {
      "name": "xmcp",
      "url": "https://github.com/xdevplatform/xmcp",
      "description": "X (Twitter) API MCP server - post tweets, read timeline, manage DMs",
